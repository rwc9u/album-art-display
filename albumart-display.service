[Unit]
Description=Album Art LED Matrix Display (shairport-sync MQTT -> RGB matrix)
After=network-online.target mosquitto.service
Wants=network-online.target mosquitto.service

[Service]
ExecStart=/usr/bin/python3 /home/rob/albumart-display/display.py
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
